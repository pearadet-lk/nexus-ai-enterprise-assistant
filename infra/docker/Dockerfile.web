FROM node:22-alpine AS build
WORKDIR /app

COPY src/NexusAI.Web/package.json src/NexusAI.Web/package-lock.json ./
RUN npm ci

COPY src/NexusAI.Web/ ./

ARG VITE_API_BASE_URL=http://localhost:5000
ARG VITE_KEYCLOAK_URL=http://localhost:8080
ARG VITE_KEYCLOAK_REALM=nexusai
ARG VITE_KEYCLOAK_CLIENT_ID=nexusai-web

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_KEYCLOAK_URL=$VITE_KEYCLOAK_URL
ENV VITE_KEYCLOAK_REALM=$VITE_KEYCLOAK_REALM
ENV VITE_KEYCLOAK_CLIENT_ID=$VITE_KEYCLOAK_CLIENT_ID

RUN npm run build

FROM nginx:alpine
COPY infra/docker/nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
