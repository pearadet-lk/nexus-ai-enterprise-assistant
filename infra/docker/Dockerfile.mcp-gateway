FROM mcr.microsoft.com/dotnet/sdk:10.0-preview AS build
WORKDIR /src
COPY . .
RUN dotnet restore src/NexusAI.McpGateway/NexusAI.McpGateway.csproj
RUN dotnet publish src/NexusAI.McpGateway/NexusAI.McpGateway.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0-preview
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 8080
ENTRYPOINT ["dotnet", "NexusAI.McpGateway.dll"]
