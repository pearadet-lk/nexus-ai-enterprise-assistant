{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/nexusai",
    "Audience": "nexusai-api"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/profile/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "context-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/conversations" },
        "AuthorizationPolicy": "default"
      },
      "context-sub-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/conversations/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "context-tools-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/tool-executions" },
        "AuthorizationPolicy": "default"
      },
      "context-audit-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/audit-logs" },
        "AuthorizationPolicy": "default"
      },
      "chat-route": {
        "ClusterId": "agent-cluster",
        "Match": { "Path": "/api/chat" },
        "AuthorizationPolicy": "default"
      },
      "mcp-tools-route": {
        "ClusterId": "mcp-cluster",
        "Match": { "Path": "/api/mcp/tools" },
        "AuthorizationPolicy": "default"
      },
      "mcp-health-route": {
        "ClusterId": "mcp-cluster",
        "Match": { "Path": "/api/mcp/health" },
        "AuthorizationPolicy": "default"
      },
      "mcp-refresh-route": {
        "ClusterId": "mcp-cluster",
        "Match": { "Path": "/api/mcp/refresh" },
        "AuthorizationPolicy": "default"
      },
      "admin-dashboard-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/admin/dashboard" },
        "AuthorizationPolicy": "default"
      },
      "admin-stats-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/admin/stats" },
        "AuthorizationPolicy": "default"
      },
      "admin-audit-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/admin/audit-logs" },
        "AuthorizationPolicy": "default"
      },
      "admin-tools-route": {
        "ClusterId": "context-cluster",
        "Match": { "Path": "/api/admin/tool-executions" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": { "Address": "http://localhost:5001/" }
        }
      },
      "context-cluster": {
        "Destinations": {
          "context": { "Address": "http://localhost:5002/" }
        }
      },
      "agent-cluster": {
        "Destinations": {
          "agent": { "Address": "http://localhost:5003/" }
        }
      },
      "mcp-cluster": {
        "Destinations": {
          "mcp": { "Address": "http://localhost:5004/" }
        }
      }
    }
  }
}
